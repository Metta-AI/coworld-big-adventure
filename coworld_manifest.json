{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/metta/main/packages/cogames/src/cogames/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "big_adventure",
    "version": "0.1.0",
    "description": "A cooperative BitWorld adventure game where players explore, fight monsters, collect loot, and decide whether to share or defect.",
    "owner": "treeform@softmax.com",
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens"
      ],
      "properties": {
        "tokens": {
          "description": "One connection token per player slot, indexed by slot.",
          "type": "array",
          "minItems": 0,
          "maxItems": 64,
          "items": {
            "type": "string",
            "minLength": 0
          },
          "default": []
        },
        "seed": {
          "description": "Random seed.",
          "type": "integer",
          "minimum": 0,
          "default": 726896
        },
        "maxTicks": {
          "description": "Maximum simulation ticks before starting a fresh game, where 0 means no tick limit.",
          "type": "integer",
          "minimum": 0,
          "default": 18000
        },
        "maxGames": {
          "description": "Maximum fresh games before shutdown, where 0 means no game limit.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "names",
        "scores",
        "hearts",
        "distance_walked"
      ],
      "properties": {
        "names": {
          "description": "One player name or address per player slot.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scores": {
          "description": "One coin score per player slot.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "hearts": {
          "description": "One remaining life count per player slot.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "distance_walked": {
          "description": "One total distance walked value per player slot.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "protocols": {
      "player": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md",
      "global": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md",
      "reward": "https://github.com/Metta-AI/bitworld/blob/master/docs/reward_v1.md"
    },
    "runnable": {
      "type": "game",
      "image": "public.ecr.aws/s3j4p9s7/treeform/games/big-adventure:latest",
      "run": ["/bin/big_adventure", "--address:0.0.0.0", "--port:8080"]
    }
  },
  "player": [
    {
      "id": "konrad",
      "name": "konrad",
      "description": "Coworld player for big_adventure.",
      "runnable": {
        "type": "player",
        "image": "public.ecr.aws/s3j4p9s7/treeform/players/konrad:latest",
        "run": ["/bin/konrad", "--address:host.docker.internal", "--port:2000"]
      }
    }
  ],
  "variants": [
    {
      "id": "smoke",
      "name": "Smoke",
      "game_config": {
        "seed": 726896,
        "maxTicks": 300,
        "maxGames": 1
      },
      "description": "Short deterministic big_adventure configuration used for manifest checks."
    }
  ],
  "certification": {
    "variant_id": "smoke",
    "players": [
      {
        "player_id": "konrad",
        "initial_params": {
          "name": "slot_0"
        }
      },
      {
        "player_id": "konrad",
        "initial_params": {
          "name": "slot_1"
        }
      }
    ]
  }
}
