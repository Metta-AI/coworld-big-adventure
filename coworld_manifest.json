{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/metta/main/packages/coworld/src/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "big_adventure",
    "version": "0.1.0",
    "description": "A cooperative BitWorld adventure game where players explore, fight monsters, collect loot, and decide whether to share or defect.",
    "owner": "treeform@softmax.com",
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens"
      ],
      "properties": {
        "tokens": {
          "description": "One connection token per player slot, indexed by slot.",
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "seed": {
          "description": "Random seed.",
          "type": "integer",
          "minimum": 0,
          "default": 726896
        },
        "maxTicks": {
          "description": "Maximum simulation ticks before starting a fresh game, where 0 means no tick limit.",
          "type": "integer",
          "minimum": 0,
          "default": 18000
        },
        "maxGames": {
          "description": "Maximum fresh games before shutdown, where 0 means no game limit.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "names",
        "scores",
        "hearts",
        "distance_walked"
      ],
      "properties": {
        "names": {
          "description": "One player name or address per player slot.",
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string"
          }
        },
        "scores": {
          "description": "One coin score per player slot.",
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "hearts": {
          "description": "One remaining life count per player slot.",
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "distance_walked": {
          "description": "One total distance walked value per player slot.",
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "protocols": {
      "player": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      },
      "global": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      }
    },
    "docs": {
      "pages": [
        {
          "id": "rules.md",
          "title": "rules.md",
          "content": {
            "type": "text",
            "value": "# Big Adventure Rules\n\nPlayers explore the world, fight monsters, collect coins and hearts, and try to survive. Final results report each player's coins, hearts, and distance walked."
          }
        },
        {
          "id": "play_big_adventure.md",
          "title": "play_big_adventure.md",
          "content": {
            "type": "text",
            "value": "# Play Big Adventure\n\nConnect to the player websocket and follow the BitWorld sprite protocol. Use the global websocket to spectate the full map."
          }
        },
        {
          "id": "reward.md",
          "title": "reward.md",
          "content": {
            "type": "uri",
            "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/reward_v1.md"
          }
        }
      ]
    },
    "runnable": {
      "type": "game",
      "image": "public.ecr.aws/s3j4p9s7/treeform/games/big-adventure:latest",
      "run": ["/bin/big_adventure"]
    }
  },
  "player": [
    {
      "id": "konrad",
      "name": "konrad",
      "description": "Coworld player for big_adventure.",
      "type": "player",
      "image": "public.ecr.aws/s3j4p9s7/treeform/players/konrad:latest",
      "run": ["/bin/konrad", "--exit-on-disconnect"]
    }
  ],
  "reporter": [
    {
      "id": "default-reporter",
      "name": "Default Reporter",
      "description": "Default reporter placeholder for Big Adventure episodes.",
      "type": "reporter",
      "image": "ghcr.io/metta-ai/reporters-default@sha256:05729bdac8cec841655dd532ec09f1706e516f7af09825310c63351307251183"
    }
  ],
  "grader": [
    {
      "id": "bitworld-score-grader",
      "name": "BitWorld Score Grader",
      "type": "grader",
      "description": "Generic BitWorld grader that scores episode interest from score spread and game-specific activity signals.",
      "source_url": "https://github.com/Metta-AI/graders/tree/main/graders/bitworld_score/bitworld_score_grader",
      "image": "ghcr.io/metta-ai/graders-bitworld-score:latest"
    }
  ],
  "variants": [
    {
      "id": "smoke",
      "name": "Smoke",
      "game_config": {
        "seed": 726896,
        "maxTicks": 300,
        "maxGames": 0
      },
      "description": "Short deterministic big_adventure configuration used for manifest checks."
    }
  ],
  "certification": {
    "game_config": {
      "seed": 726896,
      "maxTicks": 300,
      "maxGames": 0
    },
    "players": [
      {
        "player_id": "konrad"
      },
      {
        "player_id": "konrad"
      }
    ]
  }
}
